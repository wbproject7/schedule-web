# ============================================================
# ShiftMaker 환경변수 설정
# ============================================================

# [필수 - 배포] Supabase PostgreSQL 연결 문자열
# Supabase Dashboard > Settings > Database > Connection string (URI) 에서 복사
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# [선택] 보안 시크릿 키 (미설정 시 자동 생성)
# SECRET_KEY=your-random-secret-key

# [선택] CORS 허용 도메인 (쉼표 구분, 기본값: *)
# ALLOWED_ORIGINS=https://shiftmaker.onrender.com

# [선택] 로컬 개발용 SQLite 경로 (DATABASE_URL 미설정 시 사용)
# DB_PATH=./schedule.db
